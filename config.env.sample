# BreakTest self-host runtime configuration
# Copy to config.env and adjust before production use.

BREAKTEST_VERSION=rc-selfhost-1
BREAKTEST_IMAGE_REGISTRY=breakingit
BREAKTEST_COMPOSE_PROJECT_NAME=breaktest

CONTROLLER_HOST=localhost
ENABLE_SSL=false
LETS_ENCRYPT_EMAIL=admin@example.com
HTTP_PORT=80
HTTPS_PORT=443
TRAEFIK_ENTRYPOINTS=web
TRAEFIK_TLS=false
TRAEFIK_CERT_RESOLVER=letsencrypt
TRAEFIK_FRONTEND_RULE='PathPrefix(`/`)'
TRAEFIK_BACKEND_RULE='PathPrefix(`/api`)'
TRAEFIK_WEBSOCKET_RULE='PathPrefix(`/ws`)'
TRAEFIK_PG_PROXY_RULE='PathPrefix(`/ingest`) || PathPrefix(`/upsert`)'

TZ=Europe/Amsterdam
LOG_LEVEL=INFO
BACKUP_PATH=./backups

# Offline license key issued by BreakTest
BREAKTEST_LICENSE_KEY=

# Optional AI assistant. Requires a license with ai_assistant enabled and either
# ANTHROPIC_API_KEY or both OPENAI_ACCESS_TOKEN/OPENAI_REFRESH_TOKEN.
AI_ASSISTANT_ENABLED=false
HERMES_URL=http://ai-assistant:8080
HERMES_API_KEY=CHANGE_ME
ANTHROPIC_API_KEY=
OPENAI_ACCESS_TOKEN=
OPENAI_REFRESH_TOKEN=
OPENAI_TOKEN_EXPIRES=
OPENAI_EMAIL=
AI_MODEL=

# Required secrets. start.sh replaces CHANGE_ME values on first run.
JWT_SECRET_KEY=CHANGE_ME
CREDENTIAL_ENCRYPTION_KEY=
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME

# MongoDB
MONGO_DATABASE=breakingit

# TimescaleDB/PostgreSQL tuning
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_TIMEZONE=Europe/Amsterdam
POSTGRES_FSYNC=off
POSTGRES_SYNCHRONOUS_COMMIT=off
POSTGRES_FULL_PAGE_WRITES=on
POSTGRES_WORK_MEM=64MB

# pg-proxy
PG_PROXY_MAX_CONNS=100
PG_PROXY_MAX_INFLIGHT=512
PG_PROXY_COPY_TIMEOUT_SEC=60
PG_PROXY_MAX_BODY_BYTES=67108864

# Local load generator
LOAD_GENERATOR_TOKEN=local-token
LOAD_GENERATOR_NAME=loadgenerator
LOAD_GENERATOR_LOCATION=Local
LOAD_GENERATOR_RUN_MODE=process
LOAD_GENERATOR_PUBLIC=true
LOAD_GENERATOR_SUPPORTS_SYNTHETIC_MONITORING=true
LOAD_GENERATOR_CUSTOMER_NAME=Default
# Comma-separated optional services: loadgenerator,ai-assistant
COMPOSE_PROFILES=loadgenerator

# Optional cloud provider settings
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_SES_REGION=eu-west-1
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SSH_PUBLIC_KEY=
AZURE_LOADGENERATOR_IMAGE=
AZURE_CONTAINER_REGISTRY_SERVER=
AZURE_CONTAINER_REGISTRY_USERNAME=
AZURE_CONTAINER_REGISTRY_PASSWORD=
AZURE_DOCKERHUB_USERNAME=
AZURE_DOCKERHUB_TOKEN=
DOP_API_TOKEN=
DOP_SSH_KEY_NAME=
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_KEY=
